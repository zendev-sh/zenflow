[0.001, "o", "debate-until (3 steps)\r\n\r\n ┌─────────────┐\r\n │ setup       │\r\n │ (moderator) │\r\n └─────────────┘\r\n        │\r\n        ▼\r\n┌───────────────┐\r\n│ debate-rounds │\r\n│ [loop]        │\r\n└───────────────┘\r\n        │\r\n        ▼\r\n┌──────────────┐\r\n│ verdict      │\r\n│ (summarizer) │\r\n└──────────────┘\r\n\r\n"]
